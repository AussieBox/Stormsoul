{
  "schemaVersion": 1,
  "id": "stormsoul",
  "version": "${version}",
  "name": "Stormsoul",
  "description": "Merging the worlds of magic and electricity in ways never thought of before...",
  "authors": ["AussieBox"],
  "contributors": ["flingus (@flngus)", "vred (@vred_)", "N8Creates (@n8creates)"],
  "contact": {},
  "license": "MIT",
  "icon": "assets/stormsoul/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "org.aussiebox.stormsoul.client.StormsoulClient"
    ],
    "main": [
      "org.aussiebox.stormsoul.Stormsoul"
    ],
    "cardinal-components": [
      "org.aussiebox.stormsoul.StormsoulComponents"
    ],
    "jade": [
      "org.aussiebox.stormsoul.client.jade.JadePluginHandler"
    ],
    "rei_client": [
      "org.aussiebox.stormsoul.client.rei.ModREIClientPlugin"
    ],
    "rei_common": [
      "org.aussiebox.stormsoul.rei.ModREIPlugin"
    ]
  },
  "custom": {
    "cardinal-components": [
      "stormsoul:artificial_storm",
      "stormsoul:player"
    ]
  },
  "mixins": [
    "stormsoul.mixins.json",
    {
      "config": "stormsoul.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "cardinal-components-base": ">=${cca_version}",
    "cardinal-components-entity": ">=${cca_version}",
    "cardinal-components-world": ">=${cca_version}",
    "geckolib": ">=${geckolib_version}"
  },
  "recommends": {
    "continuity": "3.0.1-beta.1+1.21.6"
  }
}
